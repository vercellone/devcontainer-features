{
    "id": "sf-cli",
    "name": "Salesforce sf CLI",
    "version": "1.0.0",
    "documentationURL": "https://developer.salesforce.com/docs/atlas.en-us.sfdx_setup.meta/sfdx_setup/sfdx_setup_install_cli.htm#sfdx_setup_install_cli_linux",
    "description": "Installs the Salesforce sf CLI. (sfdx replacement)",
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "latest"
            ],
            "default": "latest",
            "description": "Version/channel to install. 'latest' installs the latest stable release from the Salesforce stable channel."
        }
    },
    "containerEnv": {
        "PATH": "/usr/local/sf/bin:${PATH}"
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
